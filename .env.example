# Copy to .env and fill in. Never commit .env.

# --- Backend ---
APP_ENV=development
APP_SECRET_KEY=change-me-32-bytes-of-random
APP_BASE_URL=http://localhost:8000
DATABASE_URL=sqlite:///./pinchtab.db

# --- Worker pool ---
WORKER_BASE_URL=http://localhost:9090
WORKER_SHARED_SECRET=change-me-used-to-derive-per-session-bearer-tokens
MAX_CONCURRENT_SESSIONS=10
SESSION_IDLE_TIMEOUT_SECONDS=30
SESSION_HARD_CAP_MINUTES=30

# --- Anthropic (operator's own key for dev only; production = BYO per user) ---
ANTHROPIC_API_KEY=

# --- Email (Resend) ---
RESEND_API_KEY=
EMAIL_FROM=noreply@pinchtab.local

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx

# --- Rate limiting ---
RATE_LIMIT_PER_USER=60/minute
